# Environment file for the vcf-ops-20s-collector systemd service.
#
# Install to /etc/vcf-ops-20s-collector/collector.env
# This file contains secrets. Lock it down:
#   sudo chown root:root /etc/vcf-ops-20s-collector/collector.env
#   sudo chmod 600       /etc/vcf-ops-20s-collector/collector.env
#
# systemd EnvironmentFile format: KEY=VALUE, one per line, no `export`, no shell
# quoting/expansion. Do NOT wrap values in quotes unless you want the quotes
# to be part of the value.

# --- VCF / Aria Operations ---
OPS_HOST=192.168.1.220
OPS_USER=admin
OPS_PASS=changeme-ops-password
# OPS_AUTH_SOURCE=LOCAL
# OPS_VERIFY_TLS=false

# --- vCenter ---
VC_HOST=vc-01.vcf-lab.local
VC_USER=administrator@vsphere.local
VC_PASS=changeme-vcenter-password
# VC_PORT=443

# --- Runtime ---
# Absolute path is safest under systemd; defaults to config.yaml next to the script.
# CONFIG_PATH=/opt/vcf-ops-20s-collector/config.yaml
# CRED_PROVIDER=env
